<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:RichillCapital.TraderStudio.Mobile.Models"
             xmlns:viewModels="clr-namespace:RichillCapital.TraderStudio.Mobile.ViewModels"
             x:Class="RichillCapital.TraderStudio.Mobile.Pages.SignalSourcesPage"
             Title="Signal sources"
             x:DataType="viewModels:SignalSourcesPageViewModel">

    <CollectionView x:Name="SignalSourceCollection" ItemsSource="{Binding SignalSources}">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:SignalSourceModel">
                <TextCell Text="{Binding Id}"></TextCell>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>